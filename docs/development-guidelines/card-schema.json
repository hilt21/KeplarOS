{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "KEPLAR Card YAML",
  "type": "object",
  "required": ["display_id", "title", "priority", "risk_level"],
  "additionalProperties": true,
  "properties": {
    "id": {
      "type": "string",
      "description": "Optional UUID primary key when the card is exported from the database."
    },
    "display_id": {
      "type": "string",
      "pattern": "^CARD-[0-9]+$"
    },
    "goal_space_id": {
      "type": "string"
    },
    "node_board_id": {
      "type": "string"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "state": {
      "type": "string",
      "enum": ["backlog", "todo", "dev", "review", "done", "blocked", "cancelled"]
    },
    "priority": {
      "type": "integer"
    },
    "risk_level": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "assigned_to": {
      "type": ["string", "null"]
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
